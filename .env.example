# Orochi environment configuration
# Copy to .env and adjust as needed:  cp .env.example .env

# Signing key for session cookies (itsdangerous). Change in production.
SECRET_KEY=dev-change-me

# Novita (Kimi) API key. Leave EMPTY to run fully offline with the deterministic LLM stub.
# Set a real key to enable live Novita calls.
NOVITA_API_KEY=

# Novita chat completions endpoint (only used when NOVITA_API_KEY is set).
NOVITA_URL=https://api.novita.ai/v1/chat/completions

# Redis-compatible connection string. For local dev outside Docker use localhost;
# inside docker-compose the backend uses redis://dragonfly:6379 automatically.
# If unreachable, the backend transparently falls back to an in-process fakeredis.
DRAGONFLY_URL=redis://localhost:6379
